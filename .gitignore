############################################
# Terraform (all subdirectories)
############################################

# Terraform working directory
**/.terraform/

# Terraform state files
**/*.tfstate
**/*.tfstate.*

# Terraform crash logs
**/crash.log

# Terraform local variables
**/*.auto.tfvars
**/*.auto.tfvars.json

############################################
# macOS
############################################
.DS_Store
**/.DS_Store

############################################
# Editor / IDE
############################################
.vscode/
.idea/
**/.vscode/
**/.idea/

############################################
# Logs
############################################
*.log
**/*.log

############################################
# Python cache (update_env.sh uses python)
############################################
**/__pycache__/
**/*.pyc
